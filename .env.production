# URL del backend ya deployado en Hostinger
REACT_APP_API_URL=https://admin.alitasdelsur.com/api

# 🖨️ SERVIDOR DE IMPRESIÓN (ngrok o local)
# ACTUALIZAR con tu URL de ngrok cuando lo inicies
# Ejemplo: REACT_APP_PRINT_SERVER_URL=https://abc123.ngrok.io
REACT_APP_PRINT_SERVER_URL=http://localhost:3001

# 💡 INSTRUCCIONES NGROK:
# 1. Ejecutar: ngrok http 3001
# 2. Copiar URL: https://abc123.ngrok.io  
# 3. Actualizar REACT_APP_PRINT_SERVER_URL con esa URL
# 4. Redesplegar frontend

